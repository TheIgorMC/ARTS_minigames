# ─── SIT Docker environment ───────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is .gitignored — never commit real values.

# Absolute path on the HOST (SSD) where campaign data lives.
# This folder is mounted into the container at /data/campaign.
CAMPAIGN_PATH=/mnt/ssd/sit-campaign

# Port exposed on the host (container always listens on 3000 internally)
SIT_PORT=3000

# Log verbosity: verbose | normal | quiet
SIT_LOG_LEVEL=normal
